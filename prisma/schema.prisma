generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  farmer
  buyer
  seller
  admin
}

enum Status {
  active
  suspended
}

enum AlertSeverity {
  info
  warning
  critical
}

enum CropType {
  Maize
  Cassava
  Tomato
  Pepper
}

enum ListingStatus {
  available
  partial
  sold
}

enum DemandStatus {
  pending
  matched
  expired
}

enum RequestStatus {
  pending
  accepted
  rejected
  completed
}

enum MatchStatus {
  pending
  confirmed
  declined
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  role      Role
  status    Status   @default(active)
  location  String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farmer    Farmer?
  buyer     Buyer?
  seller    Seller?
}

model Farmer {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  location  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields    Field[]
  listings  Listing[]
  matches   Match[]
}

model Field {
  id             String    @id @default(cuid())
  farmerId       String
  farmer         Farmer    @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  location       String
  crop           CropType
  area           Float
  ndvi           Float     @default(0)
  soilMoisture   Float     @default(0)
  lastIrrigation DateTime?
  status         Status    @default(active)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  alerts         Alert[]
}

model Buyer {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  demands   Demand[]
  requests  ListingRequest[]
  matches   Match[]
}

model Seller {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listings  Listing[]
  matches   Match[]
}

model Listing {
  id           String        @id @default(cuid()  )
  sellerId     String
  seller       Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  farmerId     String?
  farmer       Farmer?       @relation(fields: [farmerId], references: [id])
  cropType     CropType
  quantity     Int
  remainingQty Int
  location     String
  description  String
  photoUrl     String?
  status       ListingStatus @default(available)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  requests     ListingRequest[]
  matches      Match[]
}

model Demand {
  id        String       @id @default(cuid())
  buyerId   String
  buyer     Buyer        @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  cropType  CropType
  quantity  Int
  location  String
  status    DemandStatus @default(pending)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  matches   Match[]
}

model ListingRequest {
  id            String        @id @default(cuid())
  listingId     String
  listing       Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId       String
  buyer         Buyer         @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  requestedQty  Int
  message       String?
  buyerLocation String        @default("")
  status        RequestStatus @default(pending)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Match {
  id             String      @id @default(cuid())
  listingId      String
  listing        Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)
  demandId       String?
  demand         Demand?     @relation(fields: [demandId], references: [id])
  requestId      String?
  buyerId        String
  buyer          Buyer       @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  sellerId       String
  seller         Seller      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  farmerId       String?
  farmer         Farmer?     @relation(fields: [farmerId], references: [id])
  cropType       CropType
  quantity       Int
  buyerLocation  String
  sellerLocation String
  distance       Float       @default(0)
  status         MatchStatus @default(pending)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Alert {
  id         String        @id @default(cuid())
  fieldId    String
  field      Field         @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  type       String
  severity   AlertSeverity
  resolved   Boolean       @default(false)
  resolvedAt DateTime?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
}

model ContentImage {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String
  page        String
  imageUrl    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}